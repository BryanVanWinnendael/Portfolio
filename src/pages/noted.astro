---
import Layout from "@/layouts/Layout.astro"
import "@/styles/globals.css"
import NotedImage from "@/assets/images/noted/noted.svg"
import NotedImage1 from "@/assets/images/noted/noted1.png"
import NotedImage2 from "@/assets/images/noted/noted2.png"
import NotedImage3 from "@/assets/images/noted/noted3.png"
import BackNavigation from "@/components/backNavigation"
import { IoIosArrowForward } from "react-icons/io"
import DialogImage from "@/components/dialogImage"
---

<Layout title="Noted - Bryan Van Winnendael">
  <div class="w-full h-full bg-primary sm:p-5 p-2">
    <div class="bg-secondary rounded-lg">
      <BackNavigation title="Noted" client:load />
      <div class="p-5 pt-5">
        <DialogImage
          client:load
          image={NotedImage}
          classList="w-full max-h-96 rounded-md object-cover"
          transitionName="noted"
          alt="noted"
        />
        <div
          class="bg-secondary flex justify-between items-center rounded-md p-5 mt-[-70px] z-50 relative w-5/6"
        >
          <h1
            class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl text-primary"
          >
            Noted
          </h1>
          <p
            class="scroll-m-20 text-xl font-semibold tracking-tight text-muted-foreground"
          >
            2023
          </p>
        </div>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Overview
        </h4>
        <p class="leading-7 text-primary">
          Noted is a combination of notion and obsidian. It is a note taking app
          that allows you to write notes in block-style just like notion.
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Customize
        </h4>
        <p class="leading-7 text-primary">
          With the customizations, like obsidian, you can fully customize your
          application.
        </p>
        <p class="leading-7 text-primary">
          Don't like the default theme? Change it! Don't like the font? Change
          it!
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Built with
        </h4>
        <p class="leading-7 text-primary">
          Noted is built with electron, react and editor.js.
        </p>

        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Screenshots
        </h4>
        <div class="grid md:grid-cols-2 grid-cols-1 gap-5 mt-5">
          <DialogImage
            client:load
            image={NotedImage1}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted1"
          />
          <DialogImage
            client:load
            image={NotedImage2}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted2"
          />
          <DialogImage
            client:load
            image={NotedImage3}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted3"
          />
        </div>

        <div
          class="flex gap-5 bg-secondary shadow-md w-fit p-5 rounded-md mt-5"
        >
          <div>
            <p class="leading-7 text-muted-foreground">Download</p>
            <a
              target="_blank"
              href="https://github.com/BryanVanWinnendael/Noted"
              class="w-full flex items-center text-blue-500 cursor-pointer"
            >
              Download <IoIosArrowForward />
            </a>
          </div>
          <div>
            <p class="leading-7 text-muted-foreground">Code</p>
            <a
              target="_blank"
              class="w-full flex items-center text-blue-500 cursor-pointer"
              href="https://github.com/BryanVanWinnendael/Noted"
            >
              View code <IoIosArrowForward />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
