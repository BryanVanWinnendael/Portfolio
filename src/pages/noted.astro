---
import Layout from "@/layouts/Layout.astro"
import "@/styles/globals.css"
import NotedImage from "@/assets/images/noted/noted.webp"
import NotedImage1 from "@/assets/images/noted/noted2.webp"
import NotedImage2 from "@/assets/images/noted/noted3.webp"
import NotedImage3 from "@/assets/images/noted/noted4.webp"
import NotedImage4 from "@/assets/images/noted/noted5.webp"
import BackNavigation from "@/components/backNavigation"
import { IoIosArrowForward } from "react-icons/io"
import DialogImage from "@/components/dialogImage"
---

<Layout title="Noted - Bryan Van Winnendael">
  <div class="w-full h-full bg-primary sm:p-5 p-2">
    <div class="bg-secondary rounded-[24px]">
      <BackNavigation title="Noted" client:load />
      <div class="p-5 pt-5 leading-7 [&:not(:first-child)]:mt-6">
        <DialogImage
          client:load
          image={NotedImage}
          classList="w-full max-h-96 rounded-[24px] object-cover"
          transitionName="noted"
          alt="noted"
        />
        <div
          class="bg-secondary flex justify-between items-center rounded-tr-[24px] p-5 mt-[-70px] z-50 relative w-5/6"
        >
          <h1
            class="scroll-m-20 text-5xl font-black tracking-tight lg:text-6xl text-primary"
          >
            Noted
          </h1>
          <p
            class="scroll-m-20 text-xl font-semibold tracking-tight text-muted-foreground"
          >
            2023
          </p>
        </div>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Overview
        </h4>
        <p class="leading-7 text-primary">
          Noted is a combination of notion and obsidian with an inspired style
          by arc browser. It is a note taking app that allows you to write notes
          in block-style just like notion.
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Customize
        </h4>
        <p class="leading-7 text-primary">
          With the customizations, like obsidian, you can fully customize your
          application.
        </p>
        <p class="leading-7 text-primary">
          Don't like the default theme? Change it! Don't like the font? Change
          it!
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Built with
        </h4>
        <p class="leading-7 text-primary">
          Noted is built with electron, react and editor.js.
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Features
        </h4>
        <p class="leading-7 text-primary">
          For a list of all the features, please visit the <a
            class="text-blue-500"
            target="_blank"
            href="https://github.com/BryanVanWinnendael/Noted">github page</a
          > or
          <a
            class="text-blue-500"
            target="_blank"
            href="https://write-noted.vercel.app/docs">Noted Docs</a
          >.
        </p>
        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-2">
          Screenshots
        </h4>
        <div class="grid md:grid-cols-2 grid-cols-1 gap-5 mt-5">
          <DialogImage
            client:load
            image={NotedImage1}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted2"
          />
          <DialogImage
            client:load
            image={NotedImage2}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted3"
          />
          <DialogImage
            client:load
            image={NotedImage3}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted4"
          />
          <DialogImage
            client:load
            image={NotedImage4}
            classList="w-full rounded-md object-cover shadow-sm"
            alt="noted5"
          />
        </div>

        <div
          class="flex gap-5 bg-secondary shadow-md w-fit p-5 rounded-[24px] mt-5"
        >
          <div>
            <p class="leading-7 text-muted-foreground">Download</p>
            <a
              target="_blank"
              href="https://github.com/BryanVanWinnendael/Noted/releases/latest"
              class="w-full flex items-center text-blue-500 cursor-pointer"
            >
              Download <IoIosArrowForward />
            </a>
          </div>
          <div>
            <p class="leading-7 text-muted-foreground">Code</p>
            <a
              target="_blank"
              class="w-full flex items-center text-blue-500 cursor-pointer"
              href="https://github.com/BryanVanWinnendael/Noted"
            >
              View code <IoIosArrowForward />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
